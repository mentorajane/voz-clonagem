# ======================================================
# VARIÁVEIS DE AMBIENTE — Aplicativo de Clonagem de Voz
# Copie este arquivo como .env.local e preencha os valores
# ======================================================

# --- GROQ (IA que gera as respostas) ---
# Crie uma conta em https://console.groq.com
# Vá em API Keys e crie uma chave
GROQ_API_KEY=sua_chave_groq_aqui

# --- FISH AUDIO (Voz clonada — GRATUITO) ---
# Crie uma conta em https://fish.audio
# Gere sua API Key em https://fish.audio/app/api-keys
# Para clonar sua voz, POST /api/tts/clone com um arquivo de áudio (10-30s)
# Ou clone manualmente em fish.audio e cole o model_id aqui
FISH_AUDIO_API_KEY=sua_chave_fish_aqui
FISH_AUDIO_MODEL_ID=id_da_voz_clonada_aqui

# --- SUPABASE (Banco de dados — opcional) ---
# Crie uma conta em https://supabase.com
# Crie um projeto novo e vá em Settings > API
# Copie o Project URL e a anon/public key
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_supabase_aqui
